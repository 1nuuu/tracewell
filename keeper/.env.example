# Tracewell Keeper — Environment Configuration
# Copy to .env and fill in real values
# WARNING: never commit .env to version control

# Tracewell API base URL
TRACEWELL_API_URL=https://tracewell-zeta.vercel.app

# Deployed OracleFeed contract on Ritual Chain testnet
ORACLE_FEED_ADDRESS=0x19688CdD80F011814FA9a67CFe1A8e375CC7E57F

# Ritual Chain testnet RPC
RITUAL_RPC_URL=https://rpc.ritualfoundation.org

# Chain ID for Ritual Chain testnet
CHAIN_ID=1979

# Keeper private key (0x-prefixed) — NEVER commit real value here
KEEPER_PRIVATE_KEY=0x_your_keeper_private_key_here
