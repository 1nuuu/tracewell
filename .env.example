# Tracewell - Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================
# This application works with public APIs and requires no API keys by default.
# The environment variables below are optional for advanced configuration.

# -----------------------------------------------------------------------------
# CoinGecko API (Optional)
# -----------------------------------------------------------------------------
# For higher rate limits, use CoinGecko Pro API
# Get your API key at: https://www.coingecko.com/en/api/pricing
# COINGECKO_API_KEY=your_api_key_here

# -----------------------------------------------------------------------------
# Application Settings (Optional)
# -----------------------------------------------------------------------------
# Custom base URL for the application
# NEXT_PUBLIC_BASE_URL=https://tracewell.vercel.app

# Cache TTL in milliseconds (default: 120000 = 2 minutes)
# CACHE_TTL_MS=120000

# Rate limiting: max requests per minute per IP (default: 30)
# RATE_LIMIT_PER_MINUTE=30

# -----------------------------------------------------------------------------
# Analytics (Optional)
# -----------------------------------------------------------------------------
# Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_analytics_id

# =============================================================================
# NOTES
# =============================================================================
# - Never commit .env.local or .env.production files
# - Use Vercel Environment Variables for production
# - All NEXT_PUBLIC_* variables are exposed to the browser
